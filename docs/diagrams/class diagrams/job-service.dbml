Project job_service {
  database_type: "MongoDB"
}

// Conceptual class diagram for job_service.
// Jobs are persisted in MongoDB; recruiter ownership is stored as recruiter userId.

Table jobs {
  id varchar [pk]
  recruiter_id varchar [not null, note: 'Recruiter userId from gateway']
  title varchar
  normalized_title varchar
  description text
  company varchar
  location varchar
  salary_min float
  salary_max float
  job_type varchar
  experience_level varchar
  skills json
  requirements json
  benefits json
  moderation_status varchar
  visibility_status varchar
  moderation_note text
  reviewed_by varchar
  reviewed_at datetime
  deadline date
  openings int
  qualified_threshold int
  reject_threshold int
  auto_reject_enabled boolean
  required_test varchar
  deleted boolean
  deleted_at datetime
  created_at datetime
  updated_at datetime
}

// External stub to make the recruiter ownership relation visible in dbdiagram.io.
Table users {
  id varchar [pk]
}

Ref: jobs.recruiter_id > users.id

