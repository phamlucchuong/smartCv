# Notification Service — copy to backend/.env and fill in values

NOTI_SERVICE_PORT=8084

# PostgreSQL
PSQL_DSN=host=localhost user=smartcv password=smartcv dbname=smartcv_notification port=5432 sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Smart CV <noreply@smartcv.com>
SMTP_NAME=Smart CV

# SMS provider: aws_sns | twilio
# Leave empty to auto-select Twilio when configured, otherwise AWS SNS.
SMS_PROVIDER=

# AWS SNS SMS
AWS_REGION=ap-southeast-1
AWS_SNS_SMS_TYPE=Transactional
AWS_SNS_SENDER_ID=
AWS_SNS_MAX_PRICE_USD=
AWS_SNS_ORIGINATION_NUMBER=
AWS_SNS_ENTITY_ID=
AWS_SNS_TEMPLATE_ID=
# AWS credentials are resolved by the standard AWS SDK provider chain.
# Set these when running the notification service standalone outside Docker/CI.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Twilio (optional fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# Firebase Cloud Messaging (FCM)
# Project ID from the Firebase Console (General settings)
FCM_PROJECT_ID=smartcv-92c2a
# Service account key JSON — download from Firebase Console > Project Settings > Service accounts
# Paste the entire JSON as a single line (or use single quotes to preserve newlines)
FCM_SERVICE_ACCOUNT_JSON=

ENVIRONMENT=development
