CORS_ORIGINS=http://localhost:3000,http://localhost:4127

# api gateway config
USER_SERVICE_URI=http://localhost:8081
JOB_SERVICE_URI=http://localhost:8082
APP_SERVICE_URI=http://localhost:8083
NOTIFICATION_SERVICE_URI=http://localhost:8084
AI_SERVICE_URI=http://localhost:8085
PAYMENT_SERVICE_URI=http://localhost:8086

Environment=develop||production

# service ports
USER_SERVICE_PORT=8081
JOB_SERVICE_PORT=8082
APP_SERVICE_PORT=8083
NOTI_SERVICE_PORT=8084
AI_SERVICE_PORT=8085
PAYMENT_SERVICE_PORT=8086

# jwt config
JWT_SECRET_KEY=your_secret_key_here
JWT_BYPASS_TOKEN=SMARTCV_BYPASS_CANDIDATE_TOKEN
JWT_BYPASS_USER_ID=mock-candidate-user
JWT_BYPASS_SCOPE=ROLE_CANDIDATE
JWT_VALID_DURATION=5
JWT_REFRESHABLE_DURATION=1440
JWT_LONG_REFRESHABLE_DURATION=10080
GATEWAY_INTERNAL_SECRET=replace_with_strong_random_secret_32_chars_min

# db config
# mongodb
MONGO_DB_USERNAME=admin
MONGO_DB_PASSWORD=password
MONGO_DB_PORT=27017
MONGO_DB_NAME=your_db_name_here
APP_MONGO_DB_NAME=application_db
PAYMENT_MONGO_DB_NAME=payment_db

# postgresql
POSTGRES_DB_NAME=your_db_name_here
POSTGRES_DB_USER=admin
POSTGRES_DB_PASSWORD=password
POSTGRES_DB_PORT=5432
PSQL_DSN=your_postgresql_url-here

# redis config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# smtp config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_user_config
SMTP_PASSWORD=your_email_app_pwd_here
SMTP_FROM=your_email_here

# twilio config
TWILIO_ACCOUNT_SID=your_twilio_account_sID_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=your_phone_number_here

# elastic search config
ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_password

# rabbitMQ config
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# app service config
APP_DEFAULT_PAGE_SIZE=10
JOB_SERVICE_URL=http://localhost:8082/job

# ai engine config (API key, no local model)
AI_BASE_URL=https://api.groq.com/openai
AI_API_KEY=your_api_key_here
AI_MODEL=llama-3.1-8b-instant
AI_RECOMMEND_BATCH=20

# AWS S3 config (CV upload)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=your_bucket_name_here
AWS_S3_PRESIGNED_URL_TTL_MINUTES=60
# For local dev with MinIO (optional, comment out if using real AWS):
# AWS_S3_ENDPOINT_URL=http://localhost:9000

# production images
AI_SERVICE_IMAGE=smartcv/ai-engine-service:latest
