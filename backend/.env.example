CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# api gateway config
USER_SERVICE_URI=http://localhost:8081
JOB_SERVICE_URI=http://localhost:8082
APP_SERVICE_URI=http://localhost:8083
NOTIFICATION_SERVICE_URI=http://localhost:8084
AI_SERVICE_URI=http://localhost:8085
PAYMENT_SERVICE_URI=http://localhost:8086

Environment=develop||production

# service ports
USER_SERVICE_PORT=8081
JOB_SERVICE_PORT=8082
APP_SERVICE_PORT=8083
NOTI_SERVICE_PORT=8084
AI_SERVICE_PORT=8085
PAYMENT_SERVICE_PORT=8086

# jwt config
JWT_SECRET_KEY=your_secret_key_here
JWT_BYPASS_TOKEN=SMARTCV_BYPASS_CANDIDATE_TOKEN
JWT_BYPASS_USER_ID=mock-candidate-user
JWT_BYPASS_SCOPE=ROLE_CANDIDATE
JWT_VALID_DURATION=5
JWT_REFRESHABLE_DURATION=1440
JWT_LONG_REFRESHABLE_DURATION=1440
GATEWAY_INTERNAL_SECRET=replace_with_strong_random_secret_32_chars_min

# db config
# mongodb
MONGO_DB_USERNAME=admin
MONGO_DB_PASSWORD=password
MONGO_DB_PORT=27017
MONGO_DB_NAME=your_db_name_here
APP_MONGO_DB_NAME=application_db
PAYMENT_MONGO_DB_NAME=payment_db

# postgresql
POSTGRES_DB_NAME=your_db_name_here
POSTGRES_DB_USER=admin
POSTGRES_DB_PASSWORD=password
POSTGRES_DB_PORT=5432
PSQL_DSN=your_postgresql_url-here

# redis config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# smtp config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_user_config
SMTP_PASSWORD=your_email_app_pwd_here
SMTP_FROM=your_email_here

# google oauth config
GOOGLE_OAUTH_CLIENT_ID=your_google_web_client_id_here
GOOGLE_OAUTH_ALLOWED_AUDIENCES=
GOOGLE_OAUTH_JWK_SET_URI=https://www.googleapis.com/oauth2/v3/certs

# SMS provider
SMS_PROVIDER=aws_sns
# AWS_REGION is shared with the S3 config below
AWS_SNS_SMS_TYPE=Transactional
AWS_SNS_SENDER_ID=
AWS_SNS_MAX_PRICE_USD=
AWS_SNS_ORIGINATION_NUMBER=
AWS_SNS_ENTITY_ID=
AWS_SNS_TEMPLATE_ID=

# twilio config (optional fallback)
TWILIO_ACCOUNT_SID=your_twilio_account_sID_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=your_phone_number_here

# elastic search config
ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_password

# rabbitMQ config
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# app service config
APP_DEFAULT_PAGE_SIZE=10
JOB_SERVICE_URL=http://localhost:8082/job

# ai engine config
# Credentials are seeded into MongoDB on first startup, then managed via Admin API.
# Set AI_ACTIVE_PROVIDER to the provider you want active after seed.
# Supported values: groq | gemini | anthropic | azure_openai
AI_RECOMMEND_BATCH=20
AI_MONGO_DB_NAME=ai_engine_db
AI_ACTIVE_PROVIDER=groq

# --- GROQ (https://console.groq.com/keys) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# --- Google Gemini via OpenAI-compatible endpoint (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# --- Anthropic (https://console.anthropic.com/settings/keys) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# --- Azure OpenAI (https://portal.azure.com) ---
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# AWS S3 config (CV upload)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=your_bucket_name_here
AWS_S3_PRESIGNED_URL_TTL_MINUTES=60
# For local dev with MinIO (optional, comment out if using real AWS):
# AWS_S3_ENDPOINT_URL=http://localhost:9000

# payment-service (PayOS)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_TOKEN=
PAYMENT_RETURN_URL=http://localhost:3000/payment/success
PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel
USER_SERVICE_URL=http://localhost:8081/user

# production images
AI_SERVICE_IMAGE=smartcv/ai-engine-service:latest
