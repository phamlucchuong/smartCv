{
  "name": "@smart-cv/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "fetch-specs": "node scripts/fetch-specs.mjs",
    "generate": "node scripts/fetch-specs.mjs && orval",
    "generate:user": "node scripts/fetch-specs.mjs && orval --config orval.config.ts --project userService",
    "generate:job": "node scripts/fetch-specs.mjs && orval --config orval.config.ts --project jobService",
    "generate:application": "node scripts/fetch-specs.mjs && orval --config orval.config.ts --project applicationService",
    "generate:ai": "node scripts/fetch-specs.mjs && orval --config orval.config.ts --project aiService",
    "build": "tsc"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.0",
    "axios": "^1.7.9",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "orval": "^7.5.0",
    "typescript": "~6.0.2"
  }
}
