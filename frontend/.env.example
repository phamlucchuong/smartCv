# API
VITE_API_BASE_URL=https://api.example.com

# i18n
VITE_I18N_DEFAULT_LOCALE=en
VITE_I18N_FALLBACK_LOCALE=en

# port 
VITE_WEB_CANDIDATE_PORT=3000
VITE_WEB_RECRUITER_PORT=3001
VITE_WEB_ADMIN_PORT=3002
VITE_DOMAIN_URL=http://localhost:8000

# Firebase (used by all three apps for FCM push notifications)
# Get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# VAPID key from Firebase Console > Project Settings > Cloud Messaging > Web configuration
VITE_FIREBASE_VAPID_KEY=
